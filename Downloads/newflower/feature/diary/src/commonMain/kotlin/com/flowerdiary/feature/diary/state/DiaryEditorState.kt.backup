package com.flowerdiary.feature.diary.state

import com.flowerdiary.domain.model.*

/**
 * 일기 편집 화면 상태
 * SRP: 일기 편집 UI 상태만 표현
 * 불변성으로 상태 관리 단순화
 */
data class DiaryEditorState(
    val isLoading: Boolean = false,
    val isSaving: Boolean = false,
    val diaryId: DiaryId? = null,
    val title: String = "",
    val content: String = "",
    val selectedMood: Mood = Mood.PEACEFUL,
    val selectedWeather: Weather = Weather.SUNNY,
    val selectedFlower: BirthFlower? = null,
    val todayFlower: BirthFlower? = null,
    val recommendedFlowers: List<BirthFlower> = emptyList(),
    val diarySettings: DiarySettings = DiarySettings(),
    val error: String? = null,
    val isEditMode: Boolean = false
) {
    val canSave: Boolean = title.isNotBlank() || content.isNotBlank()
    val titleCharCount: Int = title.length
    val contentCharCount: Int = content.length
    
    /**
     * 꽃 선택 여부
     */
    val hasSelectedFlower: Boolean = selectedFlower != null
    
    /**
     * 일기 설정이 기본값에서 변경되었는지
     */
    val hasCustomSettings: Boolean = !diarySettings.isDefault()
}

/**
 * 일기 편집 UI 이벤트
 * SRP: 사용자 의도만 표현
 */
sealed class DiaryEditorIntent {
    /**
     * 기존 일기 로드 (편집 모드)
     */
    data class LoadDiary(val diaryId: DiaryId) : DiaryEditorIntent()
    
    /**
     * 제목 변경
     */
    data class UpdateTitle(val title: String) : DiaryEditorIntent()
    
    /**
     * 내용 변경
     */
    data class UpdateContent(val content: String) : DiaryEditorIntent()
    
    /**
     * 기분 선택
     */
    data class SelectMood(val mood: Mood) : DiaryEditorIntent()
    
    /**
     * 날씨 선택
     */
    data class SelectWeather(val weather: Weather) : DiaryEditorIntent()
    
    /**
     * 꽃 선택
     */
    data class SelectFlower(val flower: BirthFlower) : DiaryEditorIntent()
    
    /**
     * 오늘의 꽃 사용
     */
    object UseTodayFlower : DiaryEditorIntent()
    
    /**
     * 꽃 추천 요청
     */
    object RequestFlowerRecommendation : DiaryEditorIntent()
    
    /**
     * 폰트 패밀리 변경
     */
    data class ChangeFontFamily(val fontFamily: String) : DiaryEditorIntent()
    
    /**
     * 폰트 색상 변경
     */
    data class ChangeFontColor(val color: Long) : DiaryEditorIntent()
    
    /**
     * 배경 테마 변경
     */
    data class ChangeBackgroundTheme(val theme: String) : DiaryEditorIntent()
    
    /**
     * 일기 저장
     */
    object SaveDiary : DiaryEditorIntent()
    
    /**
     * 에러 메시지 제거
     */
    object ClearError : DiaryEditorIntent()
    
    /**
     * 뒤로가기
     */
    object NavigateBack : DiaryEditorIntent()
}

/**
 * 일기 편집 부수효과
 * SRP: 단발성 이벤트만 표현
 */
sealed class DiaryEditorEffect {
    /**
     * 저장 성공 후 이전 화면으로
     */
    object NavigateBack : DiaryEditorEffect()
    
    /**
     * 꽃 선택 화면 표시
     */
    object ShowFlowerPicker : DiaryEditorEffect()
    
    /**
     * 기분 선택 화면 표시
     */
    object ShowMoodPicker : DiaryEditorEffect()
    
    /**
     * 날씨 선택 화면 표시
     */
    object ShowWeatherPicker : DiaryEditorEffect()
    
    /**
     * 꾸미기 옵션 표시
     */
    object ShowDecorationOptions : DiaryEditorEffect()
    
    /**
     * 토스트 메시지
     */
    data class ShowToast(val message: String) : DiaryEditorEffect()
    
    /**
     * 변경사항 저장 확인
     */
    object ShowUnsavedChangesDialog : DiaryEditorEffect()
}
