package com.flowerdiary.feature.diary.viewmodel

import com.flowerdiary.common.constants.Config
import com.flowerdiary.common.constants.Messages
import com.flowerdiary.common.platform.DateTimeUtil
import com.flowerdiary.common.utils.Logger
import com.flowerdiary.domain.model.*
import com.flowerdiary.domain.usecase.diary.GetDiaryUseCase
import com.flowerdiary.domain.usecase.diary.SaveDiaryUseCase
import com.flowerdiary.domain.usecase.flower.GetBirthFlowerUseCase
import com.flowerdiary.domain.usecase.flower.RecommendFlowerUseCase
import com.flowerdiary.feature.diary.state.*

/**
 * 일기 편집 ViewModel
 * SRP: 일기 작성/편집 화면의 비즈니스 로직만 담당
 * 복잡한 상태 관리를 단순화
 */
class DiaryEditorViewModel(
    private val getDiaryUseCase: GetDiaryUseCase,
    private val saveDiaryUseCase: SaveDiaryUseCase,
    private val getBirthFlowerUseCase: GetBirthFlowerUseCase,
    private val recommendFlowerUseCase: RecommendFlowerUseCase
) : BaseViewModel<DiaryEditorState, DiaryEditorIntent, DiaryEditorEffect>() {
    
    init {
        loadTodayFlower()
    }
    
    override fun createInitialState(): DiaryEditorState = DiaryEditorState()
    
    override fun processIntent(intent: DiaryEditorIntent) {
        when (intent) {
            is DiaryEditorIntent.LoadDiary -> loadDiary(intent.diaryId)
            is DiaryEditorIntent.UpdateTitle -> updateTitle(intent.title)
            is DiaryEditorIntent.UpdateContent -> updateContent(intent.content)
            is DiaryEditorIntent.SelectMood -> selectMood(intent.mood)
            is DiaryEditorIntent.SelectWeather -> selectWeather(intent.weather)
            is DiaryEditorIntent.SelectFlower -> selectFlower(intent.flower)
            is DiaryEditorIntent.UseTodayFlower -> useTodayFlower()
            is DiaryEditorIntent.RequestFlowerRecommendation -> requestFlowerRecommendation()
            is DiaryEditorIntent.ChangeFontFamily -> changeFontFamily(intent.fontFamily)
            is DiaryEditorIntent.ChangeFontColor -> changeFontColor(intent.color)
            is DiaryEditorIntent.ChangeBackgroundTheme -> changeBackgroundTheme(intent.theme)
            is DiaryEditorIntent.SaveDiary -> saveDiary()
            is DiaryEditorIntent.ClearError -> clearError()
            is DiaryEditorIntent.NavigateBack -> navigateBack()
        }
    }
    
    override fun handleError(throwable: Throwable) {
        updateState {
            copy(
                error = throwable.message ?: Messages.ERROR_GENERAL,
                isLoading = false,
                isSaving = false
            )
        }
    }
    
    /**
     * 오늘의 꽃 로드
     */
    private fun loadTodayFlower() {
        launch {
            val today = DateTimeUtil.getCurrentDate()
            getBirthFlowerUseCase.getByDate(today.month, today.day)
                .onSuccess { flower ->
                    updateState {
                        copy(todayFlower = flower)
                    }
                }
                .onFailure { error ->
                    Logger.error(TAG, "Failed to load today's flower", error)
                }
        }
    }
    
    /**
     * 기존 일기 로드 (편집 모드)
     */
    private fun loadDiary(diaryId: DiaryId) {
        updateState { copy(isLoading = true) }
        
        launch {
            getDiaryUseCase(diaryId)
                .onSuccess { diary ->
                    if (diary != null) {
                        loadFlowerForDiary(diary)
                        updateState {
                            copy(
                                isLoading = false,
                                isEditMode = true,
                                diaryId = diary.id,
                                title = diary.title,
                                content = diary.content,
                                selectedMood = diary.mood,
                                selectedWeather = diary.weather,
                                diarySettings = DiarySettings(
                                    fontFamily = diary.fontFamily,
                                    fontColor = diary.fontColor,
                                    backgroundTheme = diary.backgroundTheme
                                )
                            )
                        }
                    } else {
                        handleError(NoSuchElementException(Messages.ERROR_DIARY_NOT_FOUND))
                    }
                }
                .onFailure { error ->
                    Logger.error(TAG, "Failed to load diary", error)
                    handleError(error)
                }
        }
    }
    
    /**
     * 일기에 연결된 꽃 정보 로드
     */
    private fun loadFlowerForDiary(diary: Diary) {
        launch {
            getBirthFlowerUseCase.getById(diary.flowerId)
                .onSuccess { flower ->
                    updateState {
                        copy(selectedFlower = flower)
                    }
                }
        }
    }
    
    /**
     * 제목 업데이트
     */
    private fun updateTitle(title: String) {
        if (title.length > Config.MAX_TITLE_LENGTH) {
            sendEffect(DiaryEditorEffect.ShowToast(Messages.validationTitleLength(Config.MAX_TITLE_LENGTH)))
            return
        }
        
        updateState { copy(title = title) }
    }
    
    /**
     * 내용 업데이트
     */
    private fun updateContent(content: String) {
        if (content.length > Config.MAX_CONTENT_LENGTH) {
            sendEffect(DiaryEditorEffect.ShowToast(Messages.validationContentLength(Config.MAX_CONTENT_LENGTH)))
            return
        }
        
        updateState { copy(content = content) }
    }
    
    /**
     * 기분 선택
     */
    private fun selectMood(mood: Mood) {
        updateState { copy(selectedMood = mood) }
    }
    
    /**
     * 날씨 선택
     */
    private fun selectWeather(weather: Weather) {
        updateState { copy(selectedWeather = weather) }
    }
    
    /**
     * 꽃 선택
     */
    private fun selectFlower(flower: BirthFlower) {
        updateState { copy(selectedFlower = flower) }
    }
    
    /**
     * 오늘의 꽃 사용
     */
    private fun useTodayFlower() {
        currentState.todayFlower?.let { flower ->
            updateState { copy(selectedFlower = flower) }
            sendEffect(DiaryEditorEffect.ShowToast(Messages.SUCCESS_FLOWER_SELECTED))
        } ?: sendEffect(DiaryEditorEffect.ShowToast(Messages.ERROR_FLOWER_NOT_AVAILABLE))
    }
    
    /**
     * 꽃 추천 요청
     */
    private fun requestFlowerRecommendation() {
        launch {
            recommendFlowerUseCase.recommendByMoodAndWeather(
                mood = currentState.selectedMood,
                weather = currentState.selectedWeather
            ).onSuccess { flower ->
                if (flower != null) {
                    updateState { copy(selectedFlower = flower) }
                    sendEffect(DiaryEditorEffect.ShowToast(Messages.recommendationFlower(flower.nameKr)))
                } else {
                    sendEffect(DiaryEditorEffect.ShowToast(Messages.ERROR_NO_RECOMMENDED_FLOWER))
                }
            }
        }
    }
    
    /**
     * 폰트 패밀리 변경
     */
    private fun changeFontFamily(fontFamily: String) {
        updateState {
            copy(diarySettings = diarySettings.copy(fontFamily = fontFamily))
        }
    }
    
    /**
     * 폰트 색상 변경
     */
    private fun changeFontColor(color: Long) {
        updateState {
            copy(diarySettings = diarySettings.copy(fontColor = color))
        }
    }
    
    /**
     * 배경 테마 변경
     */
    private fun changeBackgroundTheme(theme: String) {
        updateState {
            copy(diarySettings = diarySettings.copy(backgroundTheme = theme))
        }
    }
    
    /**
     * 일기 저장
     */
    private fun saveDiary() {
        if (!currentState.canSave) {
            sendEffect(DiaryEditorEffect.ShowToast(Messages.VALIDATION_EMPTY_CONTENT))
            return
        }
        
        val flower = currentState.selectedFlower ?: currentState.todayFlower
        if (flower == null) {
            sendEffect(DiaryEditorEffect.ShowToast(Messages.VALIDATION_NO_FLOWER))
            sendEffect(DiaryEditorEffect.ShowFlowerPicker)
            return
        }
        
        updateState { copy(isSaving = true) }
        
        launch {
            val diary = createDiaryFromState(flower)
            
            saveDiaryUseCase(diary)
                .onSuccess {
                    sendEffect(DiaryEditorEffect.ShowToast(
                        if (currentState.isEditMode) Messages.SUCCESS_DIARY_UPDATED 
                        else Messages.SUCCESS_DIARY_SAVED
                    ))
                    sendEffect(DiaryEditorEffect.NavigateBack)
                }
                .onFailure { error ->
                    Logger.error(TAG, "Failed to save diary", error)
                    handleError(error)
                }
        }
    }
    
    /**
     * 현재 상태로부터 Diary 엔티티 생성
     */
    private fun createDiaryFromState(flower: BirthFlower): Diary {
        val now = DateTimeUtil.now()
        
        return if (currentState.isEditMode && currentState.diaryId != null) {
            // 편집 모드
            Diary(
                id = currentState.diaryId!!,
                title = currentState.title,
                content = currentState.content,
                mood = currentState.selectedMood,
                weather = currentState.selectedWeather,
                flowerId = flower.id,
                fontFamily = currentState.diarySettings.fontFamily,
                fontColor = currentState.diarySettings.fontColor,
                backgroundTheme = currentState.diarySettings.backgroundTheme,
                createdAt = now, // 실제로는 기존 값 유지해야 함
                updatedAt = now
            )
        } else {
            // 새 일기
            Diary(
                id = DiaryId.generate(),
                title = currentState.title,
                content = currentState.content,
                mood = currentState.selectedMood,
                weather = currentState.selectedWeather,
                flowerId = flower.id,
                fontFamily = currentState.diarySettings.fontFamily,
                fontColor = currentState.diarySettings.fontColor,
                backgroundTheme = currentState.diarySettings.backgroundTheme,
                createdAt = now,
                updatedAt = now
            )
        }
    }
    
    /**
     * 에러 메시지 제거
     * SRP: 에러 상태 클리어만 담당
     */
    private fun clearError() {
        updateState { copy(error = null) }
    }
    
    /**
     * 뒤로가기
     */
    private fun navigateBack() {
        if (currentState.canSave && !currentState.isSaving) {
            sendEffect(DiaryEditorEffect.ShowUnsavedChangesDialog)
        } else {
            sendEffect(DiaryEditorEffect.NavigateBack)
        }
    }
    
    companion object {
        private const val TAG = "DiaryEditorViewModel"
    }
}
