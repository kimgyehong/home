package com.flowerdiary.feature.diary.viewmodel

import com.flowerdiary.common.constants.Messages
import com.flowerdiary.common.utils.Logger
import com.flowerdiary.domain.model.Diary
import com.flowerdiary.domain.model.DiaryId
import com.flowerdiary.domain.usecase.diary.DeleteDiaryUseCase
import com.flowerdiary.domain.usecase.diary.GetDiariesUseCase
import com.flowerdiary.feature.diary.state.*
import kotlinx.coroutines.flow.launchIn
import kotlinx.coroutines.flow.onEach

/**
 * 일기 목록 ViewModel
 * SRP: 일기 목록 화면의 비즈니스 로직만 담당
 * MVI 패턴으로 단방향 데이터 흐름 보장
 */
class DiaryListViewModel(
    private val getDiariesUseCase: GetDiariesUseCase,
    private val deleteDiaryUseCase: DeleteDiaryUseCase
) : BaseViewModel<DiaryListState, DiaryListIntent, DiaryListEffect>() {
    
    init {
        // 초기 데이터 로드
        processIntent(DiaryListIntent.LoadDiaries)
    }
    
    override fun createInitialState(): DiaryListState = DiaryListState.Initial
    
    override fun processIntent(intent: DiaryListIntent) {
        when (intent) {
            is DiaryListIntent.LoadDiaries -> loadDiaries()
            is DiaryListIntent.RefreshDiaries -> refreshDiaries()
            is DiaryListIntent.FilterByMonth -> filterByMonth(intent.year, intent.month)
            is DiaryListIntent.ClearFilter -> clearFilter()
            is DiaryListIntent.SelectDiary -> selectDiary(intent.diary)
            is DiaryListIntent.DeleteDiary -> confirmDeleteDiary(intent.diary)
            is DiaryListIntent.CreateNewDiary -> createNewDiary()
        }
    }
    
    override fun handleError(throwable: Throwable) {
        updateState {
            DiaryListState.Error(
                message = throwable.message ?: Messages.ERROR_UNKNOWN,
                throwable = throwable,
                canRetry = true
            )
        }
    }
    
    /**
     * 일기 목록 로드
     */
    private fun loadDiaries() {
        if (currentState is DiaryListState.Loading) return
        
        updateState { DiaryListState.Loading }
        
        launch {
            getDiariesUseCase.getAll()
                .onSuccess { diaries ->
                    updateState {
                        DiaryListState.Success(
                            diaries = diaries.sortedByDescending { it.createdAt }
                        )
                    }
                }
                .onFailure { error ->
                    Logger.error(TAG, "Failed to load diaries", error)
                    handleError(error)
                }
        }
    }
    
    /**
     * 일기 목록 새로고침
     */
    private fun refreshDiaries() {
        val currentSuccess = currentState as? DiaryListState.Success ?: return
        
        updateState {
            currentSuccess.copy(isRefreshing = true)
        }
        
        launch {
            getDiariesUseCase.getAll()
                .onSuccess { diaries ->
                    updateState {
                        currentSuccess.copy(
                            diaries = diaries.sortedByDescending { it.createdAt },
                            isRefreshing = false
                        )
                    }
                }
                .onFailure { error ->
                    Logger.error(TAG, "Failed to refresh diaries", error)
                    updateState {
                        currentSuccess.copy(isRefreshing = false)
                    }
                    sendEffect(DiaryListEffect.ShowToast(Messages.ERROR_REFRESH_FAILED))
                }
        }
    }
    
    /**
     * 월별 필터링
     */
    private fun filterByMonth(year: Int, month: Int) {
        val currentSuccess = currentState as? DiaryListState.Success ?: return
        
        updateState {
            currentSuccess.copy(
                selectedYear = year,
                selectedMonth = month
            )
        }
    }
    
    /**
     * 필터 초기화
     */
    private fun clearFilter() {
        val currentSuccess = currentState as? DiaryListState.Success ?: return
        
        updateState {
            currentSuccess.copy(
                selectedYear = null,
                selectedMonth = null
            )
        }
    }
    
    /**
     * 일기 선택
     */
    private fun selectDiary(diary: Diary) {
        sendEffect(DiaryListEffect.NavigateToDiaryDetail(diary.id.value))
    }
    
    /**
     * 일기 삭제 확인
     */
    private fun confirmDeleteDiary(diary: Diary) {
        sendEffect(DiaryListEffect.ShowDeleteConfirmation(diary))
    }
    
    /**
     * 일기 삭제 실행
     */
    fun deleteDiary(diaryId: DiaryId) {
        launch {
            deleteDiaryUseCase(diaryId)
                .onSuccess {
                    sendEffect(DiaryListEffect.ShowToast(Messages.SUCCESS_DIARY_DELETED))
                    loadDiaries() // 목록 새로고침
                }
                .onFailure { error ->
                    Logger.error(TAG, "Failed to delete diary", error)
                    sendEffect(DiaryListEffect.ShowToast(Messages.ERROR_DELETE_FAILED))
                }
        }
    }
    
    /**
     * 새 일기 작성
     */
    private fun createNewDiary() {
        sendEffect(DiaryListEffect.NavigateToCreateDiary)
    }
    
    companion object {
        private const val TAG = "DiaryListViewModel"
    }
}
