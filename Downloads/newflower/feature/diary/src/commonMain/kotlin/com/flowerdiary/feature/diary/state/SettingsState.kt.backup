package com.flowerdiary.feature.diary.state

import com.flowerdiary.common.constants.Config

/**
 * 설정 화면 상태
 * SRP: 설정 UI 상태만 표현
 * 앱 전체 설정 관리
 */
data class SettingsState(
    val isLoading: Boolean = false,
    val bgmEnabled: Boolean = true,
    val bgmVolume: Float = Config.BGM_VOLUME_DEFAULT,
    val bgmTrackIndex: Int = 0,
    val fontSizeScale: Float = 1.0f,
    val notificationsEnabled: Boolean = true,
    val autoUnlockEnabled: Boolean = true,
    val themeMode: ThemeMode = ThemeMode.SYSTEM,
    val error: String? = null
) {
    /**
     * BGM 볼륨 퍼센트 (0-100)
     */
    val bgmVolumePercent: Int = (bgmVolume * PERCENT_MULTIPLIER).toInt()
    
    /**
     * 폰트 크기 레벨
     */
    val fontSizeLevel: FontSizeLevel = when {
        fontSizeScale < FONT_SIZE_SMALL_THRESHOLD -> FontSizeLevel.SMALL
        fontSizeScale > FONT_SIZE_LARGE_THRESHOLD -> FontSizeLevel.LARGE
        else -> FontSizeLevel.MEDIUM
    }
    
    companion object {
        private const val PERCENT_MULTIPLIER = 100f
        private const val FONT_SIZE_SMALL_THRESHOLD = 0.9f
        private const val FONT_SIZE_LARGE_THRESHOLD = 1.1f
    }
}

/**
 * 테마 모드
 */
enum class ThemeMode(val displayName: String) {
    LIGHT("밝은 테마"),
    DARK("어두운 테마"),
    SYSTEM("시스템 설정")
}

/**
 * 폰트 크기 레벨
 */
enum class FontSizeLevel(val scale: Float, val displayName: String) {
    SMALL(0.85f, "작게"),
    MEDIUM(1.0f, "보통"),
    LARGE(1.15f, "크게")
}

/**
 * 설정 UI 이벤트
 * SRP: 사용자 의도만 표현
 */
sealed class SettingsIntent {
    /**
     * 설정 로드
     */
    object LoadSettings : SettingsIntent()
    
    /**
     * BGM 활성화 토글
     */
    object ToggleBGM : SettingsIntent()
    
    /**
     * BGM 볼륨 변경
     */
    data class ChangeBGMVolume(val volume: Float) : SettingsIntent()
    
    /**
     * BGM 트랙 변경
     */
    data class ChangeBGMTrack(val trackIndex: Int) : SettingsIntent()
    
    /**
     * 폰트 크기 변경
     */
    data class ChangeFontSize(val level: FontSizeLevel) : SettingsIntent()
    
    /**
     * 알림 토글
     */
    object ToggleNotifications : SettingsIntent()
    
    /**
     * 자동 해금 토글
     */
    object ToggleAutoUnlock : SettingsIntent()
    
    /**
     * 테마 변경
     */
    data class ChangeTheme(val mode: ThemeMode) : SettingsIntent()
    
    /**
     * 캐시 삭제
     */
    object ClearCache : SettingsIntent()
    
    /**
     * 데이터 초기화
     */
    object ResetData : SettingsIntent()
}

/**
 * 설정 부수효과
 * SRP: 단발성 이벤트만 표현
 */
sealed class SettingsEffect {
    /**
     * BGM 재생/정지
     */
    data class PlayBGM(val trackIndex: Int) : SettingsEffect()
    object StopBGM : SettingsEffect()
    
    /**
     * 볼륨 변경
     */
    data class SetBGMVolume(val volume: Float) : SettingsEffect()
    
    /**
     * 테마 적용
     */
    data class ApplyTheme(val mode: ThemeMode) : SettingsEffect()
    
    /**
     * 토스트 메시지
     */
    data class ShowToast(val message: String) : SettingsEffect()
    
    /**
     * 확인 다이얼로그
     */
    object ShowResetConfirmation : SettingsEffect()
    
    /**
     * 앱 재시작 필요
     */
    object RequireRestart : SettingsEffect()
}
