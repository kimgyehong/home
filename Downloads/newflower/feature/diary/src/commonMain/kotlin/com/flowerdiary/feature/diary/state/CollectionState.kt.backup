package com.flowerdiary.feature.diary.state

import com.flowerdiary.domain.model.BirthFlower

/**
 * 도감 화면 상태
 * SRP: 도감 UI 상태만 표현
 * 월별 그룹화 및 잠금 상태 관리
 */
data class CollectionState(
    val isLoading: Boolean = false,
    val flowers: List<BirthFlower> = emptyList(),
    val selectedMonth: Int? = null,
    val todayFlower: BirthFlower? = null,
    val unlockedCount: Int = 0,
    val totalCount: Int = TOTAL_FLOWERS,
    val error: String? = null,
    val selectedFlower: BirthFlower? = null
) {
    /**
     * 월별로 그룹화된 꽃 목록
     */
    val flowersByMonth: Map<Int, List<BirthFlower>> by lazy {
        flowers.groupBy { it.month }
    }
    
    /**
     * 선택된 월의 꽃 목록
     */
    val filteredFlowers: List<BirthFlower> = 
        selectedMonth?.let { month ->
            flowersByMonth[month] ?: emptyList()
        } ?: flowers
    
    /**
     * 수집 진행률 (퍼센트)
     */
    val collectionProgress: Float = 
        if (totalCount > 0) (unlockedCount.toFloat() / totalCount) * PERCENT_MULTIPLIER
        else 0f
    
    /**
     * 모든 꽃 수집 완료 여부
     */
    val isCompleted: Boolean = unlockedCount >= totalCount
    
    companion object {
        private const val TOTAL_FLOWERS = 365
        private const val PERCENT_MULTIPLIER = 100f
    }
}

/**
 * 도감 UI 이벤트
 * SRP: 사용자 의도만 표현
 */
sealed class CollectionIntent {
    /**
     * 도감 데이터 로드
     */
    object LoadCollection : CollectionIntent()
    
    /**
     * 오늘의 꽃 해금
     */
    object UnlockTodayFlower : CollectionIntent()
    
    /**
     * 월 필터 적용
     */
    data class FilterByMonth(val month: Int?) : CollectionIntent()
    
    /**
     * 꽃 상세 보기
     */
    data class ViewFlowerDetail(val flower: BirthFlower) : CollectionIntent()
    
    /**
     * 꽃 상세 닫기
     */
    object CloseFlowerDetail : CollectionIntent()
    
    /**
     * 도감 새로고침
     */
    object RefreshCollection : CollectionIntent()
}

/**
 * 도감 부수효과
 * SRP: 단발성 이벤트만 표현
 */
sealed class CollectionEffect {
    /**
     * 꽃 상세 팝업 표시
     */
    data class ShowFlowerDetail(val flower: BirthFlower) : CollectionEffect()
    
    /**
     * 새로운 꽃 해금 애니메이션
     */
    data class ShowUnlockAnimation(val flower: BirthFlower) : CollectionEffect()
    
    /**
     * 토스트 메시지
     */
    data class ShowToast(val message: String) : CollectionEffect()
    
    /**
     * 모든 꽃 수집 완료 축하
     */
    object ShowCompletionCelebration : CollectionEffect()
    
    /**
     * 공유하기
     */
    data class ShareFlower(val flower: BirthFlower) : CollectionEffect()
}
