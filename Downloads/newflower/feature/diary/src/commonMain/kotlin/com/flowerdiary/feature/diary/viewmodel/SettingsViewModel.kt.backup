package com.flowerdiary.feature.diary.viewmodel

import com.flowerdiary.common.constants.Config
import com.flowerdiary.common.constants.Messages
import com.flowerdiary.common.platform.AudioManager
import com.flowerdiary.common.platform.PreferencesStore
import com.flowerdiary.common.platform.FileStore
import com.flowerdiary.common.utils.ExceptionUtil
import com.flowerdiary.common.utils.Logger
import com.flowerdiary.feature.diary.state.*
import kotlinx.coroutines.flow.update
import kotlinx.coroutines.launch

/**
 * 설정 화면 ViewModel
 * SRP: 설정 화면의 상태 관리와 비즈니스 로직만 담당
 * MVI 패턴으로 사용자 의도를 상태 변경으로 변환
 */
class SettingsViewModel(
    private val preferencesStore: PreferencesStore,
    private val audioManager: AudioManager,
    private val fileStore: FileStore
) : BaseViewModel<SettingsState, SettingsIntent, SettingsEffect>(
    initialState = SettingsState()
) {
    
    init {
        loadSettings()
    }
    
    override fun handleIntent(intent: SettingsIntent) {
        when (intent) {
            is SettingsIntent.LoadSettings -> loadSettings()
            is SettingsIntent.ToggleBGM -> toggleBGM()
            is SettingsIntent.ChangeBGMVolume -> changeBGMVolume(intent.volume)
            is SettingsIntent.ChangeBGMTrack -> changeBGMTrack(intent.trackIndex)
            is SettingsIntent.ChangeFontSize -> changeFontSize(intent.level)
            is SettingsIntent.ToggleNotifications -> toggleNotifications()
            is SettingsIntent.ToggleAutoUnlock -> toggleAutoUnlock()
            is SettingsIntent.ChangeTheme -> changeTheme(intent.mode)
            is SettingsIntent.ClearCache -> clearCache()
            is SettingsIntent.ResetData -> showResetConfirmation()
        }
    }
    
    /**
     * 설정 불러오기
     */
    private fun loadSettings() {
        viewModelScope.launch {
            _state.update { it.copy(isLoading = true) }
            
            ExceptionUtil.runCatching {
                val bgmEnabled = preferencesStore.getBoolean(KEY_BGM_ENABLED, true)
                val bgmVolume = preferencesStore.getFloat(KEY_BGM_VOLUME, 0.7f)
                val bgmTrackIndex = preferencesStore.getInt(KEY_BGM_TRACK, 0)
                val fontScale = preferencesStore.getFloat(KEY_FONT_SCALE, 1.0f)
                val notifications = preferencesStore.getBoolean(KEY_NOTIFICATIONS, true)
                val autoUnlock = preferencesStore.getBoolean(KEY_AUTO_UNLOCK, true)
                val themeMode = preferencesStore.getString(KEY_THEME, ThemeMode.SYSTEM.name)
                
                _state.update {
                    it.copy(
                        isLoading = false,
                        bgmEnabled = bgmEnabled,
                        bgmVolume = bgmVolume,
                        bgmTrackIndex = bgmTrackIndex,
                        fontSizeScale = fontScale,
                        notificationsEnabled = notifications,
                        autoUnlockEnabled = autoUnlock,
                        themeMode = ThemeMode.valueOf(themeMode ?: ThemeMode.SYSTEM.name),
                        error = null
                    )
                }
                
                // BGM 상태 동기화
                if (bgmEnabled) {
                    sendEffect(SettingsEffect.PlayBGM(bgmTrackIndex))
                    sendEffect(SettingsEffect.SetBGMVolume(bgmVolume))
                }
            }.onFailure { e ->
                Logger.error(TAG, "Failed to load settings", e)
                _state.update {
                    it.copy(isLoading = false, error = Messages.ERROR_SETTINGS_LOAD_FAILED)
                }
            }
        }
    }
    
    /**
     * BGM 토글
     */
    private fun toggleBGM() {
        viewModelScope.launch {
            val newEnabled = !_state.value.bgmEnabled
            
            ExceptionUtil.runCatching {
                preferencesStore.putBoolean(KEY_BGM_ENABLED, newEnabled)
                _state.update { it.copy(bgmEnabled = newEnabled) }
                
                if (newEnabled) {
                    sendEffect(SettingsEffect.PlayBGM(_state.value.bgmTrackIndex))
                } else {
                    sendEffect(SettingsEffect.StopBGM)
                }
            }.onFailure { e ->
                Logger.error(TAG, "Failed to toggle BGM", e)
                sendEffect(SettingsEffect.ShowToast("BGM 설정 변경 실패"))
            }
        }
    }
    
    /**
     * BGM 볼륨 변경
     */
    private fun changeBGMVolume(volume: Float) {
        viewModelScope.launch {
            ExceptionUtil.runCatching {
                preferencesStore.putFloat(KEY_BGM_VOLUME, volume)
                _state.update { it.copy(bgmVolume = volume) }
                sendEffect(SettingsEffect.SetBGMVolume(volume))
            }.onFailure { e ->
                Logger.error(TAG, "Failed to change BGM volume", e)
            }
        }
    }
    
    /**
     * BGM 트랙 변경
     */
    private fun changeBGMTrack(trackIndex: Int) {
        viewModelScope.launch {
            ExceptionUtil.runCatching {
                preferencesStore.putInt(KEY_BGM_TRACK, trackIndex)
                _state.update { it.copy(bgmTrackIndex = trackIndex) }
                
                if (_state.value.bgmEnabled) {
                    sendEffect(SettingsEffect.PlayBGM(trackIndex))
                }
            }.onFailure { e ->
                Logger.error(TAG, "Failed to change BGM track", e)
            }
        }
    }
    
    /**
     * 폰트 크기 변경
     */
    private fun changeFontSize(level: FontSizeLevel) {
        viewModelScope.launch {
            ExceptionUtil.runCatching {
                preferencesStore.putFloat(KEY_FONT_SCALE, level.scale)
                _state.update { it.copy(fontSizeScale = level.scale) }
                sendEffect(SettingsEffect.ShowToast(Messages.SUCCESS_FONT_SIZE_CHANGED))
            }.onFailure { e ->
                Logger.error(TAG, "Failed to change font size", e)
            }
        }
    }
    
    /**
     * 알림 토글
     */
    private fun toggleNotifications() {
        viewModelScope.launch {
            val newEnabled = !_state.value.notificationsEnabled
            
            ExceptionUtil.runCatching {
                preferencesStore.putBoolean(KEY_NOTIFICATIONS, newEnabled)
                _state.update { it.copy(notificationsEnabled = newEnabled) }
                
                val message = if (newEnabled) Messages.SUCCESS_NOTIFICATION_ENABLED else Messages.SUCCESS_NOTIFICATION_DISABLED
                sendEffect(SettingsEffect.ShowToast(message))
            }.onFailure { e ->
                Logger.error(TAG, "Failed to toggle notifications", e)
            }
        }
    }
    
    /**
     * 자동 해금 토글
     */
    private fun toggleAutoUnlock() {
        viewModelScope.launch {
            val newEnabled = !_state.value.autoUnlockEnabled
            
            ExceptionUtil.runCatching {
                preferencesStore.putBoolean(KEY_AUTO_UNLOCK, newEnabled)
                _state.update { it.copy(autoUnlockEnabled = newEnabled) }
            }.onFailure { e ->
                Logger.error(TAG, "Failed to toggle auto unlock", e)
            }
        }
    }
    
    /**
     * 테마 변경
     */
    private fun changeTheme(mode: ThemeMode) {
        viewModelScope.launch {
            ExceptionUtil.runCatching {
                preferencesStore.putString(KEY_THEME, mode.name)
                _state.update { it.copy(themeMode = mode) }
                sendEffect(SettingsEffect.ApplyTheme(mode))
            }.onFailure { e ->
                Logger.error(TAG, "Failed to change theme", e)
            }
        }
    }
    
    /**
     * 캐시 삭제
     */
    private fun clearCache() {
        viewModelScope.launch {
            _state.update { it.copy(isLoading = true) }
            
            ExceptionUtil.runCatching {
                fileStore.clearCache()
                _state.update { it.copy(isLoading = false) }
                sendEffect(SettingsEffect.ShowToast(Messages.SUCCESS_CACHE_DELETED))
            }.onFailure { e ->
                Logger.error(TAG, "Failed to clear cache", e)
                _state.update {
                    it.copy(isLoading = false, error = Messages.ERROR_CACHE_DELETE_FAILED)
                }
            }
        }
    }
    
    /**
     * 초기화 확인 다이얼로그 표시
     */
    private fun showResetConfirmation() {
        sendEffect(SettingsEffect.ShowResetConfirmation)
    }
    
    /**
     * 데이터 초기화 실행
     */
    fun executeReset() {
        viewModelScope.launch {
            _state.update { it.copy(isLoading = true) }
            
            ExceptionUtil.runCatching {
                // 모든 설정 초기화
                preferencesStore.clear()
                fileStore.clearAll()
                
                _state.update { it.copy(isLoading = false) }
                sendEffect(SettingsEffect.RequireRestart)
            }.onFailure { e ->
                Logger.error(TAG, "Failed to reset data", e)
                _state.update {
                    it.copy(isLoading = false, error = Messages.ERROR_DATA_RESET_FAILED)
                }
            }
        }
    }
    
    companion object {
        private const val TAG = "SettingsViewModel"
    }
}
