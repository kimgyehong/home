package com.flowerdiary.domain.usecase.flower

import com.flowerdiary.common.platform.DateTimeUtil
import com.flowerdiary.common.utils.Logger
import com.flowerdiary.domain.model.BirthFlower
import com.flowerdiary.domain.model.Mood
import com.flowerdiary.domain.model.Weather
import com.flowerdiary.domain.repository.BirthFlowerRepository

/**
 * 꽃 추천 유스케이스
 * 기분, 날씨, 계절에 따른 꽃 추천 로직
 * OCP(개방-폐쇄 원칙) 적용 - 새로운 추천 전략 추가 가능
 */
class RecommendFlowerUseCase(
    private val birthFlowerRepository: BirthFlowerRepository
) {
    /**
     * 기분과 날씨에 따른 꽃 추천
     */
    suspend fun recommendByMoodAndWeather(
        mood: Mood,
        weather: Weather
    ): Result<BirthFlower?> {
        Logger.debug(TAG, "Recommending flower for mood: $mood, weather: $weather")
        
        // 해금된 꽃 목록 가져오기
        val unlockedFlowers = birthFlowerRepository.findUnlocked().getOrNull()
        if (unlockedFlowers.isNullOrEmpty()) {
            Logger.warning(TAG, "No unlocked flowers available for recommendation")
            return Result.success(null)
        }
        
        // 추천 점수 계산
        val scoredFlowers = unlockedFlowers.map { flower ->
            val score = calculateScore(flower, mood, weather)
            flower to score
        }.sortedByDescending { it.second }
        
        val recommendedFlower = scoredFlowers.firstOrNull()?.first
        
        if (recommendedFlower != null) {
            Logger.info(TAG, "Recommended flower: ${recommendedFlower.nameKr}")
        } else {
            Logger.info(TAG, "No suitable flower found for recommendation")
        }
        
        return Result.success(recommendedFlower)
    }
    
    /**
     * 오늘의 추천 꽃 (오늘 날짜의 탄생화)
     */
    suspend fun recommendTodayFlower(): Result<BirthFlower?> {
        val today = DateTimeUtil.getCurrentDate()
        Logger.debug(TAG, "Getting today's recommended flower: ${today.month}/${today.day}")
        
        return birthFlowerRepository.findByDate(today.month, today.day)
            .onSuccess { flower ->
                if (flower != null) {
                    Logger.info(TAG, "Today's flower: ${flower.nameKr}")
                } else {
                    Logger.warning(TAG, "No flower found for today")
                }
            }
            .onFailure { 
                Logger.error(TAG, "Failed to get today's flower", it)
            }
    }
    
    /**
     * 꽃 추천 점수 계산
     * 기분과 날씨에 따른 가중치 적용
     */
    private fun calculateScore(flower: BirthFlower, mood: Mood, weather: Weather): Int {
        var score = 0
        
        // 기분에 따른 점수
        when (mood) {
            Mood.HAPPY, Mood.EXCITED, Mood.LOVE -> {
                if (flower.meaning.contains("행복") || 
                    flower.meaning.contains("사랑") || 
                    flower.meaning.contains("기쁨")) {
                    score += 10
                }
            }
            Mood.SAD, Mood.TIRED -> {
                if (flower.meaning.contains("위로") || 
                    flower.meaning.contains("희망") || 
                    flower.meaning.contains("평안")) {
                    score += 10
                }
            }
            Mood.PEACEFUL, Mood.GRATEFUL -> {
                if (flower.meaning.contains("감사") || 
                    flower.meaning.contains("평화") || 
                    flower.meaning.contains("조화")) {
                    score += 10
                }
            }
            else -> score += 5 // 기본 점수
        }
        
        // 날씨에 따른 점수
        when (weather) {
            Weather.SUNNY -> {
                if (flower.meaning.contains("밝") || 
                    flower.meaning.contains("빛")) {
                    score += 5
                }
            }
            Weather.RAINY, Weather.CLOUDY -> {
                if (flower.meaning.contains("우아") || 
                    flower.meaning.contains("고요")) {
                    score += 5
                }
            }
            else -> score += 2 // 기본 점수
        }
        
        // 계절에 따른 점수 (월 기준)
        val currentMonth = DateTimeUtil.getCurrentDate().month
        if (flower.month == currentMonth) {
            score += 15 // 현재 월의 꽃 우선
        } else if (kotlin.math.abs(flower.month - currentMonth) <= 1) {
            score += 8 // 인접한 월의 꽃
        }
        
        return score
    }
    
    companion object {
        private const val TAG = "RecommendFlowerUseCase"
    }
}
