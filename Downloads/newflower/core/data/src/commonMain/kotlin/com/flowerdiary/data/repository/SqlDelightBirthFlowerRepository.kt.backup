package com.flowerdiary.data.repository

import app.cash.sqldelight.coroutines.asFlow
import app.cash.sqldelight.coroutines.mapToList
import app.cash.sqldelight.coroutines.mapToOneOrNull
import com.flowerdiary.common.utils.ExceptionUtil
import com.flowerdiary.common.utils.Logger
import com.flowerdiary.data.FlowerDiaryDatabase
import com.flowerdiary.data.model.BirthFlowerMapper.toDomain
import com.flowerdiary.domain.model.BirthFlower
import com.flowerdiary.domain.model.FlowerId
import com.flowerdiary.domain.repository.BirthFlowerRepository
import com.flowerdiary.common.platform.DefaultDispatcher
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.map

/**
 * SQLDelight 기반 탄생화 저장소 구현
 * SOLID 원칙 준수 - 인터페이스에 의존, 구체적 구현 제공
 */
class SqlDelightBirthFlowerRepository(
    private val database: FlowerDiaryDatabase
) : BirthFlowerRepository {
    
    private val queries = database.birthFlowerQueries
    
    override suspend fun findById(id: FlowerId): Result<BirthFlower?> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Finding birth flower by id: ${id.value}")
            queries.selectById(id.value.toLong())
                .executeAsOneOrNull()
                ?.toDomain()
        }
    
    override suspend fun findByDate(month: Int, day: Int): Result<BirthFlower?> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Finding birth flower by date: $month/$day")
            queries.selectByDate(month.toLong(), day.toLong())
                .executeAsOneOrNull()
                ?.toDomain()
        }
    
    override suspend fun findAll(): Result<List<BirthFlower>> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Finding all birth flowers")
            queries.selectAll()
                .executeAsList()
                .map { it.toDomain() }
        }
    
    override suspend fun findUnlocked(): Result<List<BirthFlower>> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Finding unlocked birth flowers")
            queries.selectUnlocked()
                .executeAsList()
                .map { it.toDomain() }
        }
    
    override suspend fun findByMonth(month: Int): Result<List<BirthFlower>> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Finding birth flowers for month: $month")
            queries.selectByMonth(month.toLong())
                .executeAsList()
                .map { it.toDomain() }
        }
    
    override suspend fun unlock(id: FlowerId): Result<Unit> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Unlocking birth flower: ${id.value}")
            queries.unlock(id.value.toLong())
        }
    
    override suspend fun unlockToday(month: Int, day: Int): Result<Unit> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Unlocking today's birth flower: $month/$day")
            queries.unlockByDate(month.toLong(), day.toLong())
        }
    
    override suspend fun countUnlocked(): Result<Int> =
        ExceptionUtil.runCatchingSuspend {
            Logger.debug(TAG, "Counting unlocked birth flowers")
            queries.countUnlocked()
                .executeAsOne()
                .toInt()
        }
    
    override fun observeAll(): Flow<List<BirthFlower>> =
        queries.selectAll()
            .asFlow()
            .mapToList(DefaultDispatcher)
            .map { list -> list.map { it.toDomain() } }
    
    override fun observeById(id: FlowerId): Flow<BirthFlower?> =
        queries.selectById(id.value.toLong())
            .asFlow()
            .mapToOneOrNull(DefaultDispatcher)
            .map { it?.toDomain() }
    
    override fun observeUnlockStatus(): Flow<Int> =
        queries.countUnlocked()
            .asFlow()
            .mapToOneOrNull(DefaultDispatcher)
            .map { it?.toInt() ?: 0 }
    
    companion object {
        private const val TAG = "SqlDelightBirthFlowerRepository"
    }
}
